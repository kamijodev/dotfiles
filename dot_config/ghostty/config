# Font
font-family = Maple Mono NF
font-size = 14

# Theme
theme = Gruvbox Material Dark
background = #32302f
background-opacity = 0.97

# Window
window-padding-x = 32
window-padding-y = 32
window-decoration = false
window-theme = ghostty
gtk-titlebar = false

# Tab
gtk-tabs-location = top
window-save-state = always

# Split
unfocused-split-opacity = 1.0
split-divider-color = #504945

# Cursor
cursor-style = block
shell-integration-features = no-cursor

# Misc
command = zellij
shell-integration = zsh
confirm-close-surface = false
mouse-scroll-multiplier = 2

# Keybinds

# Claude Code (Shift+Enter)
keybind = shift+enter=text:\x1b[13;2u

# Tab
keybind = ctrl+tab=next_tab
keybind = ctrl+backspace=previous_tab
keybind = ctrl+shift+t=new_tab
keybind = super+w=close_surface
keybind = ctrl+shift+bracket_left=move_tab:-1
keybind = ctrl+shift+bracket_right=move_tab:1

# Split
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+shift+v=new_split:right
keybind = ctrl+shift+/=close_surface

# Split navigation
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+j=goto_split:bottom
keybind = super+shift+h=goto_split:left
keybind = super+shift+l=goto_split:right
keybind = super+shift+k=goto_split:top
keybind = super+shift+j=goto_split:bottom

# Split resize
keybind = ctrl+arrow_left=resize_split:left,10
keybind = ctrl+arrow_right=resize_split:right,10
keybind = ctrl+arrow_up=resize_split:up,10
keybind = ctrl+arrow_down=resize_split:down,10

# Split zoom
keybind = ctrl+shift+z=toggle_split_zoom

# Copy/Paste
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Font size
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+-=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# Fullscreen
keybind = alt+enter=toggle_fullscreen

# Reload config
keybind = ctrl+shift+r=reload_config

# Command palette
keybind = ctrl+shift+p=toggle_command_palette
keybind = super+p=toggle_command_palette
