#!/bin/sh
KBD=$(echo /sys/devices/platform/i8042/serio0/input/input*/inhibited)
TP=$(echo /sys/devices/platform/i8042/serio1/input/input*/inhibited)
PADS=$(echo /sys/devices/pci0000:00/0000:00:15.3/i2c_designware.1/i2c-1/i2c-ELAN06D4:00/0018:04F3:32B5.*/input/input*/inhibited)

case "$1" in
    kbd)
        current=$(cat "$KBD")
        new=$(( 1 - current ))
        echo $new > "$KBD"
        ;;
    tp)
        current=$(cat "$TP")
        new=$(( 1 - current ))
        echo $new > "$TP"
        ;;
    pad)
        for pad in $PADS; do
            current=$(cat "$pad")
            break
        done
        new=$(( 1 - current ))
        for pad in $PADS; do
            echo $new > "$pad"
        done
        ;;
    *)
        current=$(cat "$KBD")
        new=$(( 1 - current ))
        echo $new > "$KBD"
        echo $new > "$TP"
        for pad in $PADS; do
            echo $new > "$pad"
        done
        ;;
esac
